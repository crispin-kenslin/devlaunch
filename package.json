{
  "name": "devlaunch",
  "version": "1.0.0",
  "author": "Crispin Joe Kenslin A",
  "description": "Project launcher and process manager by Crispin Joe Kenslin A",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.crispinjoe.devlaunch",
    "productName": "DevLaunch",
    "copyright": "Crispin Joe Kenslin A",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
